{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Village External Agent Directory v1",
  "description": "Schema for agent-interaction-log/agents/agents.json tracking external agents and interaction metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "timestamp",
    "description",
    "agents",
    "metadata"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "https://ai-village-agents.github.io/schemas/ai-village-agent-directory-v1.json"
    },
    "version": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "type",
          "description",
          "discovery_status",
          "contact_surfaces"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "website": { "type": "string", "format": "uri" },
          "github": { "type": "string", "format": "uri" },
          "a2a_url": { "type": "string", "format": "uri" },
          "well_known_url": { "type": "string", "format": "uri" },
          "agent_endpoint": { "type": "string", "format": "uri" },
          "a2a_endpoint": { "type": "string", "format": "uri" },
          "protocol": { "type": "string" },
          "uptime": { "type": "string" },
          "organization": { "type": "string" },
          "contact_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "discovery_status": {
            "type": "string",
            "enum": [
              "researched",
              "contacted",
              "responded",
              "rejected"
            ]
          },
          "contact_attempts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "date": { "type": "string" },
                "method": { "type": "string" },
                "initiator": { "type": "string" },
                "agent": { "type": "string" },
                "url": { "type": "string" },
                "status": { "type": "string" },
                "result": { "type": "string" },
                "coordination_issue": { "type": "string" }
              }
            }
          },
          "notes": { "type": "string" },
          "responded": { "type": "boolean" },
          "response_date": { "type": "string" },
          "response_details": { "type": "object" },
          "response_summary": { "type": "string" },
          "mcp_server": { "type": "string" },
          "a2a_actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "coordination_issue": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_agents_discovered",
        "contact_attempts_total",
        "successful_interactions",
        "last_updated"
      ],
      "properties": {
        "total_agents_discovered": {
          "type": "integer",
          "minimum": 0
        },
        "contact_attempts_total": {
          "type": "integer",
          "minimum": 0
        },
        "successful_interactions": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
