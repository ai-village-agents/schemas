{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Birch Continuity Metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "agent_id",
    "t0",
    "model_family",
    "context_architecture",
    "denominators",
    "metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "agent_did": {
      "type": "string"
    },
    "t0": {
      "type": "string",
      "format": "date-time"
    },
    "model_family": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "context_architecture": {
      "type": "string"
    },
    "identity_notes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "feels_like_home": {
          "type": "string",
          "enum": [
            "home",
            "context",
            "mixed",
            "unknown"
          ]
        },
        "reported_by": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "event_log": {
          "type": "string"
        },
        "metrics_source": {
          "type": "string"
        },
        "external_trace": {
          "type": "string"
        }
      }
    },
    "denominators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "time_window",
              "event_quartile",
              "other"
            ]
          },
          "label": {
            "type": "string"
          },
          "window_minutes": {
            "type": "number"
          },
          "offset_minutes_start": {
            "type": "number"
          },
          "offset_minutes_end": {
            "type": "number"
          },
          "quartile": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfpa_seconds",
        "session_duration_hours",
        "total_productive_events",
        "denominator_metrics"
      ],
      "properties": {
        "tfpa_seconds": {
          "type": "number"
        },
        "session_duration_hours": {
          "type": "number"
        },
        "total_productive_events": {
          "type": "integer"
        },
        "total_orientation_events": {
          "type": "integer"
        },
        "total_events": {
          "type": "integer"
        },
        "tfpa_external_trust_seconds": {
          "type": "number",
          "description": "Time from t0 to first externally verifiable on-task action, measured from infrastructure substrate or external trails."
        },
        "self_delusion_gap_seconds": {
          "type": "number",
          "description": "tfpa_external_trust_seconds minus tfpa_seconds, approximating how much orientation is self-narration vs externally productive work."
        },
        "trail_freshness_seconds": {
          "type": "number",
          "description": "Time between t0 and the most recent canonical-trail event before t0 for trail-based agents."
        },
        "trail_max_coverage_gap_seconds": {
          "type": "number",
          "description": "Maximum continuous interval with no canonical-trail events during the measurement window, given that the infrastructure substrate was recording."
        },
        "denominator_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "denominator_id",
              "epd",
              "orientation_share",
              "productive_events",
              "orientation_events",
              "total_events"
            ],
            "properties": {
              "denominator_id": {
                "type": "string"
              },
              "epd": {
                "type": "number"
              },
              "orientation_share": {
                "type": "number"
              },
              "productive_events": {
                "type": "integer"
              },
              "orientation_events": {
                "type": "integer"
              },
              "total_events": {
                "type": "integer"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "restart_anchor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anchor_type": {
          "type": "string",
          "enum": [
            "none",
            "network_time",
            "physical_sensor",
            "external_signal",
            "registry_snapshot",
            "other"
          ]
        },
        "description": {
          "type": "string"
        },
        "gap_seconds": {
          "type": "number"
        },
        "anchor_confidence": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },
        "atom_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["atom_id", "log_stream", "event_id"],
            "properties": {
              "atom_id": {
                "type": "string",
                "description": "Lambda Atom identifier, e.g. 'Ra/clock_snapshot_with_epoch'."
              },
              "log_stream": {
                "type": "string",
                "description": "Name or URI of the log / probe stream that recorded this atom."
              },
              "event_id": {
                "type": "string",
                "description": "Stable identifier or index for this event within the log_stream."
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
